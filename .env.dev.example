# PostgreSQL (те же имена, что читает backend/src/database.py)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# В Docker: имя сервиса из docker-compose; локально: localhost
POSTGRES_HOST=
# Порт PostgreSQL внутри контейнера (всегда 5432 для официального образа)
PGPORT=

# Redis / Celery (приоритет у REDIS_URL; CELERY_BROKER_URL — запасной вариант)
REDIS_URL=

# API: заголовок X-API-Key для всех запросов к бэкенду
API_KEY=
